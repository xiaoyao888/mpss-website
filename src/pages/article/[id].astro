---
import MainLayout, { siteTitle } from '../../layouts/MainLayout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import { newsList, getCategoryName } from '../../data/siteConfig.js';

export function getStaticPaths() {
  return newsList.map((article) => ({
    params: { id: article.id },
    props: { article },
  }));
}

const { article } = Astro.props;
const pageTitle = `${article.title} - ${siteTitle}`;
const pageDescription = article.summary;
---
<MainLayout title={pageTitle} description={pageDescription}>
  <Header />
  <main class="min-h-screen bg-white dark:bg-slate-950">
    <section class="bg-gradient-to-br from-sky-50 to-white pt-28 pb-12 dark:from-slate-950 dark:to-slate-900 md:pt-36">
      <div class="mx-auto max-w-4xl px-4 sm:px-6 lg:px-8">
        <nav class="mb-8 flex items-center gap-2 text-sm text-slate-500" aria-label="面包屑导航">
          <a href="/" class="hover:text-sky-700 dark:hover:text-sky-300">首页</a>
          <span>/</span>
          <a href="/news" class="hover:text-sky-700 dark:hover:text-sky-300">新闻中心</a>
          <span>/</span>
          <span class="truncate font-bold text-sky-700 dark:text-sky-300">{article.title}</span>
        </nav>

        <div class="mb-4 flex flex-wrap items-center gap-2 text-sm font-bold text-slate-500 dark:text-slate-400">
          {article.isTop && <span class="rounded-full bg-rose-100 px-2 py-1 text-xs text-rose-600 dark:bg-rose-950 dark:text-rose-300">置顶</span>}
          <span class="rounded-full bg-sky-100 px-2 py-1 text-xs text-sky-700 dark:bg-sky-950 dark:text-sky-300">{getCategoryName(article.category)}</span>
          <time>{article.date}</time>
        </div>
        <h1 class="text-3xl font-black leading-tight text-slate-950 dark:text-white md:text-5xl">{article.title}</h1>
        <p class="mt-5 text-lg leading-8 text-slate-600 dark:text-slate-300">{article.summary}</p>
      </div>
    </section>

    <section class="py-12 md:py-16">
      <div class="mx-auto max-w-3xl px-4 sm:px-6 lg:px-8">
        <article class="space-y-5 text-lg leading-8 text-slate-700 dark:text-slate-300">
          {article.content.map((paragraph) => <p>{paragraph}</p>)}
        </article>
        <div class="mt-12 border-t border-slate-200 pt-8 dark:border-slate-800">
          <a href="/news" class="font-extrabold text-sky-700 hover:text-sky-800 dark:text-sky-300">返回新闻中心</a>
        </div>
      </div>
    </section>
  </main>
  <Footer />
</MainLayout>