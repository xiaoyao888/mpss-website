---
import MainLayout, { siteTitle } from '../layouts/MainLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import { companyInfo, features, serviceSteps } from '../data/siteConfig.js';

const pageTitle = `预约演示 - ${siteTitle}`;
const pageDescription = `预约${companyInfo.name} SaaS 小程序与后台管理系统演示，了解标准版、定制版和交付方式。`;
---
<MainLayout title={pageTitle} description={pageDescription}>
  <Header />
  <main>
    <section class="relative overflow-hidden bg-gradient-to-br from-emerald-50 via-white to-amber-50 pt-28 pb-16 dark:from-slate-950 dark:via-slate-900 dark:to-slate-950 md:pt-36 md:pb-20">
      <div class="mx-auto max-w-4xl px-4 text-center sm:px-6 lg:px-8">
        <p class="text-sm font-black tracking-widest text-emerald-700">BOOK A DEMO</p>
        <h1 class="mt-3 text-4xl font-black text-slate-950 dark:text-white md:text-6xl">预约系统演示</h1>
        <p class="mx-auto mt-5 max-w-2xl text-lg leading-8 text-slate-600 dark:text-slate-300">了解 SaaS 小程序、后台管理系统、标准模块、定制范围和上线交付方式。</p>
      </div>
    </section>

    <section class="bg-white py-16 dark:bg-slate-950 md:py-24">
      <div class="mx-auto grid max-w-6xl gap-8 px-4 sm:px-6 lg:grid-cols-[.9fr_1.1fr] lg:px-8">
        <div class="rounded-[2rem] bg-slate-950 p-8 text-white shadow-xl shadow-slate-900/15 dark:bg-slate-900">
          <h2 class="text-3xl font-black">直接联系</h2>
          <p class="mt-4 leading-7 text-slate-300">请说明你的业务类型、是否已有小程序账号、需要标准系统还是定制开发，我们会先判断适配度再沟通报价。</p>
          <div class="mt-8 space-y-4 text-sm">
            <a href={`tel:${companyInfo.phone}`} class="block rounded-2xl bg-white px-5 py-4 font-black text-slate-950">电话：{companyInfo.phone}</a>
            <a href={`mailto:${companyInfo.email}`} class="block rounded-2xl bg-white/10 px-5 py-4 font-black text-white">邮箱：{companyInfo.email}</a>
          </div>
        </div>

        <div class="rounded-[2rem] border border-slate-100 bg-slate-50 p-8 dark:border-slate-800 dark:bg-slate-900">
          <h2 class="text-2xl font-black text-slate-950 dark:text-white">演示前建议准备</h2>
          <ol class="mt-6 list-decimal space-y-4 pl-5 text-sm leading-7 text-slate-600 dark:text-slate-300">
            <li>业务类型：商城、预约、本地生活、平台型业务或其他场景。</li>
            <li>端口需求：是否需要微信小程序、H5、PC 后台、商户后台或员工端。</li>
            <li>核心流程：客户下单、支付、核销、配送、售后、财务或分账规则。</li>
            <li>上线节奏：是快速试运行，还是需要完整定制开发。</li>
          </ol>
        </div>
      </div>
    </section>

    <section class="bg-slate-50 py-16 dark:bg-slate-900 md:py-20">
      <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
        <h2 class="text-center text-3xl font-black text-slate-950 dark:text-white">演示内容</h2>
        <div class="mt-10 grid gap-6 sm:grid-cols-2 lg:grid-cols-3">
          {features.map((feature) => (
            <article class="rounded-3xl bg-white p-6 text-center shadow-sm dark:bg-slate-800">
              <div class="text-4xl">{feature.icon}</div>
              <h3 class="mt-4 font-black text-slate-950 dark:text-white">{feature.title}</h3>
              <p class="mt-2 text-sm leading-6 text-slate-600 dark:text-slate-300">{feature.description}</p>
            </article>
          ))}
        </div>
      </div>
    </section>
  </main>
  <Footer />
</MainLayout>