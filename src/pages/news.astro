---
import MainLayout, { siteTitle } from '../layouts/MainLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import { newsList, getCategoryName } from '../data/siteConfig.js';

const pageTitle = `新闻中心 - ${siteTitle}`;
const pageDescription = '朔州秒派科技新闻中心，包含公司动态、系统交付观点和后台管理系统相关资讯。';
const companyCount = newsList.filter((item) => item.category === 'company').length;
const industryCount = newsList.filter((item) => item.category === 'industry').length;
---
<MainLayout title={pageTitle} description={pageDescription}>
  <Header />
  <main>
    <section class="relative bg-cover bg-center pt-28 pb-16 md:pt-36" style="background-image: url('/images/news_bg.png');">
      <div class="absolute inset-0 bg-slate-950/55"></div>
      <div class="relative mx-auto max-w-7xl px-4 text-center sm:px-6 lg:px-8">
        <p class="text-sm font-black tracking-widest text-emerald-200">NEWS</p>
        <h1 class="mt-3 text-4xl font-black text-white md:text-5xl">新闻中心</h1>
        <p class="mt-4 text-lg text-slate-200">了解公司动态与系统交付相关资讯</p>
      </div>
    </section>

    <section class="bg-white py-12 dark:bg-slate-950 md:py-16">
      <div class="mx-auto max-w-4xl px-4 sm:px-6 lg:px-8">
        <nav class="mb-8 flex items-center gap-2 text-sm text-slate-500" aria-label="面包屑导航">
          <a href="/" class="hover:text-emerald-700 dark:hover:text-emerald-300">首页</a>
          <span>/</span>
          <span class="font-bold text-emerald-700 dark:text-emerald-300">新闻中心</span>
        </nav>

        <div id="category-tabs" class="mb-10 flex flex-wrap gap-2 border-b border-slate-200 pb-6 dark:border-slate-800">
          <button data-category="all" class="category-btn rounded-full bg-emerald-700 px-5 py-2.5 text-sm font-bold text-white shadow-sm">全部 {newsList.length}</button>
          <button data-category="company" class="category-btn rounded-full bg-slate-100 px-5 py-2.5 text-sm font-bold text-slate-700 transition hover:bg-slate-200 dark:bg-slate-800 dark:text-slate-200">公司动态 {companyCount}</button>
          <button data-category="industry" class="category-btn rounded-full bg-slate-100 px-5 py-2.5 text-sm font-bold text-slate-700 transition hover:bg-slate-200 dark:bg-slate-800 dark:text-slate-200">行业资讯 {industryCount}</button>
        </div>

        <div id="news-list" class="space-y-6">
          {newsList.map((news) => (
            <article data-category={news.category} class="news-item border-b border-slate-100 pb-6 last:border-0 dark:border-slate-800">
              <div class="flex flex-col gap-3 sm:flex-row sm:items-start sm:justify-between">
                <div>
                  <div class="mb-2 flex items-center gap-2 text-xs font-bold text-slate-400">
                    {news.isTop && <span class="rounded-full bg-rose-100 px-2 py-1 text-rose-600 dark:bg-rose-950 dark:text-rose-300">置顶</span>}
                    <span>{getCategoryName(news.category)}</span>
                  </div>
                  <a href={`/article/${news.id}/`} class="text-xl font-black text-slate-950 transition hover:text-emerald-700 dark:text-white dark:hover:text-emerald-300">{news.title}</a>
                  <p class="mt-3 line-clamp-2 text-sm leading-6 text-slate-600 dark:text-slate-300">{news.summary}</p>
                </div>
                <time class="shrink-0 text-sm font-semibold text-slate-400">{news.date}</time>
              </div>
            </article>
          ))}
        </div>
      </div>
    </section>
  </main>
  <Footer />
</MainLayout>

<script>
  const tabs = document.querySelectorAll('.category-btn');
  const items = document.querySelectorAll('.news-item');
  tabs.forEach((btn) => {
    btn.addEventListener('click', () => {
      const category = btn.dataset.category;
      tabs.forEach((tab) => {
        tab.classList.remove('bg-emerald-700', 'text-white', 'shadow-sm');
        tab.classList.add('bg-slate-100', 'text-slate-700', 'dark:bg-slate-800', 'dark:text-slate-200');
      });
      btn.classList.add('bg-emerald-700', 'text-white', 'shadow-sm');
      btn.classList.remove('bg-slate-100', 'text-slate-700', 'dark:bg-slate-800', 'dark:text-slate-200');
      items.forEach((item) => {
        item.style.display = category === 'all' || item.dataset.category === category ? '' : 'none';
      });
    });
  });
</script>