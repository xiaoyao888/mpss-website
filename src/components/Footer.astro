---
import { companyInfo } from '../data/siteConfig.js';
---
<footer class="bg-gray-900 text-gray-300 dark:bg-black" id="contact">
  <div class="mx-auto max-w-7xl px-4 py-12 sm:px-6 lg:px-8">
    <div class="grid grid-cols-1 gap-8 md:grid-cols-3">
      <div>
        <h3 class="mb-4 text-lg font-bold text-white">{companyInfo.name}</h3>
        <p class="mb-3 text-sm leading-relaxed text-gray-400">{companyInfo.tagline}</p>
        <p class="mb-3 text-sm leading-relaxed text-gray-400">{companyInfo.slogan}</p>
        <p class="text-xs text-gray-500">{companyInfo.copyright}</p>
      </div>

      <div>
        <h3 class="mb-4 text-lg font-bold text-white">联系我们</h3>
        <ul class="space-y-2 text-sm">
          <li class="flex items-start">
            <svg xmlns="http://www.w3.org/2000/svg" class="mr-2 mt-0.5 h-4 w-4 flex-shrink-0 text-blue-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" />
            </svg>
            <span>电话：<a href={`tel:${companyInfo.phone}`} class="transition-colors hover:text-white">{companyInfo.phone}</a></span>
          </li>
          <li class="flex items-start">
            <svg xmlns="http://www.w3.org/2000/svg" class="mr-2 mt-0.5 h-4 w-4 flex-shrink-0 text-blue-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />
            </svg>
            <span>邮箱：<a href={`mailto:${companyInfo.email}`} class="transition-colors hover:text-white">{companyInfo.email}</a></span>
          </li>
          <li class="flex items-start">
            <svg xmlns="http://www.w3.org/2000/svg" class="mr-2 mt-0.5 h-4 w-4 flex-shrink-0 text-blue-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z" />
              <path stroke-linecap="round" stroke-linejoin="round" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z" />
            </svg>
            <span>地址：{companyInfo.address}</span>
          </li>
        </ul>
      </div>

      <div>
        <h3 class="mb-4 text-lg font-bold text-white">资质信息</h3>
        <ul class="space-y-2 text-sm text-gray-400">
          <li><span class="text-gray-500">公司全称：</span><span>{companyInfo.fullName}</span></li>
          <li><span class="text-gray-500">统一社会信用代码：</span><span>{companyInfo.license}</span></li>
          <li><span class="text-gray-500">备案号码：</span><a href="https://beian.miit.gov.cn/" target="_blank" rel="noopener noreferrer" class="transition-colors hover:text-white">{companyInfo.icp}</a></li>
        </ul>
      </div>
    </div>

    <div class="mt-8 border-t border-gray-800 pt-8 text-center">
      <p class="text-xs text-gray-500">
        {companyInfo.name}专注 SaaS 小程序与后台管理系统交付，帮助企业更快启动线上业务。
      </p>
    </div>
  </div>
</footer>